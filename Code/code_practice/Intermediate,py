# 1. Write a function to find factorial using recursion.
from functools import lru_cache
@lru_cache(maxsize=None)
def factorial(n: int)-> int:
    if n < 0:
        raise ValueError("Number must be no-negative")
    if n in (0, 1):
        return 1  
    return n * factorial(n - 1)
