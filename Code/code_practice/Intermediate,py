# 2. Create a function to check palindrome string.
def palindrome(text):
    reverse_text = text[::-1]
    if text == reverse_text:
        return " palindrome"
    else:
        return "Not palindrome"
# print(palindrome("121"))

## palindrome without slicing
def check_palindrome(value):
    value = str(value)
    n = len(value)
    is_palindrome = True
    #sirf half check karte hain
    for i in range(n // 2):
        if value[i] != value[n - i - 1]:
            is_palindrome = False
            break
    if is_palindrome:
        return "Palindrome"
    else:
        return "Not Palindrome"
