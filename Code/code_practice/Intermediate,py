# Strings
# 1. Reverse a string without slicing.
def reverse_string(text):
    reversed_text = " "
    for ch in text:
        reversed_text = ch + reversed_text
    return reversed_text
# print(reverse_string("suraj"))

# 2. Count uppercase and lowercase letters.
def count_case(text):
    upper = sum(1 for ch in text if ch.isupper())
    lower = sum(1 for ch in text if ch.islower())
    return upper, lower
# print(count_case("SuRaJ"))
    
# 3. Find duplicate characters in a string.
def duplicate_char(text):
    freq = {}
    duplicate = []
    for ch in text:
        freq[ch] = freq.get(ch, 0) + 1
    
    for ch in freq:
        if freq[ch] > 1:
            duplicate.append(ch)
    return duplicate
print(duplicate_char("surajkumar"))

